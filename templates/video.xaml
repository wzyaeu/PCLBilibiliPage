<local:MyCard Margin="5"
              Width="272"
              Height="200">
    <StackPanel Margin="3">
        <Grid Margin="7,7,7,0" Height="140">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <local:MyImage
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Source="{img}"/>
            </StackPanel>
            <Border VerticalAlignment="Bottom"
                    Height="22"
                    Background="Black"
                    Opacity="0.4"/>
            <StackPanel VerticalAlignment="Bottom"
                        Margin="4"
                        Orientation="Horizontal">
                <Path Width="13"
                      Margin="2,0,0,0"
                      Height="13"
                      VerticalAlignment="Center"
                      Stretch="Uniform"
                      Fill="{DynamicResource ColorBrush8}"
                      Style="{StaticResource view_svgdata}"/>
                <TextBlock
                    Margin="2,0,0,0"
                    FontSize="13"
                    Foreground="{DynamicResource ColorBrush8}"
                    Text="{view}"/>
                <Path Width="13"
                      Margin="2,0,0,0"
                      Height="13"
                      VerticalAlignment="Center"
                      Stretch="Uniform"
                      Fill="{DynamicResource ColorBrush8}"
                      Style="{StaticResource danmaku_svgdata}"/>
                <TextBlock
                    Margin="2,0,0,0"
                    FontSize="13"
                    Foreground="{DynamicResource ColorBrush8}"
                    Text="{danmaku}"/>
                <TextBlock
                    Margin="2,0,0,0"
                    FontSize="13"
                    Foreground="{DynamicResource ColorBrush8}"
                    Text="{date} {up}"
                    ToolTip="{date} {up}"/>
            </StackPanel>
        </Grid>
        <TextBlock Margin="7,4,7,0"
                   FontWeight="Bold"
                   FontSize="15"
                   Height="17"
                   Foreground="{DynamicResource ColorBrush1}"
                   Text="{title}"
                   ToolTip="{title}"/>
        <StackPanel Margin="7,3,7,0"
                    Orientation="Horizontal">
            <local:MyButton
                Margin="1,0,1,0"
                Height="18"
                Width="50"
                Text="查看"
                EventType="打开网页"
                EventData="{url}"/>
            <local:MyButton
                Margin="1,0,1,0"
                Height="18"
                Width="50"
                Text="信息"
                EventType="弹出窗口"
                EventData="详细信息|标题：{title}\n简介：{desc}\n\n播放：{view}\n弹幕：{danmaku}\n点赞：{like}\n投币：{coin}\n收藏：{favorite}\n分享：{share}"/>
        </StackPanel>
    </StackPanel>
</local:MyCard>